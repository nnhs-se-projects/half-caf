<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Half Caf</title>
    <link rel="stylesheet" href="/css/pico.min.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="shortcut icon" type="image/png" href="/img/logo.png" />
    <style>
      @media screen and (max-width: 768px) {
        .full-title {
          display: none;
        }
        #leftTrigger {
          display: none;
        }
      }
      @media screen and (min-width: 769px) {
        .mobile-title {
          display: none;
        }
        /* Updated arrow trigger styling */
        #leftTrigger {
          position: fixed;
          top: 50%;
          left: 20px; /* attached to collapsed sidebar edge */
          transform: translateY(-50%);
          width: 24px;
          height: 24px;
          background: var(--coffee-medium);
          cursor: pointer;
          z-index: 1003; /* Higher than sidebar so it's clickable */
          transition: left 0.3s ease;
          opacity: 0.9;
          border-radius: 4px;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        #leftTrigger span {
          display: block;
          text-align: center;
          color: white;
          line-height: 24px;
          font-size: 14px;
        }
        /* Arrow position is controlled by JS to avoid stale position */
      }
    </style>
  </head>
  <body>
    <div class="container" id="logo">
      <%- include('_header') %>
      <h1 class="indexTopBar">
        <span class="full-title">NNHS Half Caf Barista</span>
        <span class="mobile-title">Barista</span>
      </h1>
    </div>

    <!-- Reorder: sidebar first then arrow trigger -->
    <div id="sidebar">
      <a href="/barista/orders">Orders</a>
      <a href="/barista/pointOfSale">Point of Sale</a>
      <a href="/barista/completedOrders">Order History</a>
      <a href="/delivery/login">Deliverer</a>
      <a href="https://forms.gle/uqQ8SiAY4BUPCTJp8" target="_blank">Feedback</a>
      <a href="https://forms.gle/MuZF7T39r9adDQRT8" target="_blank"
        >Report a bug</a
      >

      <% if (role === "admin") { %>
      <a href="/admin/users">Admin</a>
      <% } %>

      <a href="/auth/logout">Logout</a>

      <% let numOfNewOrders = 0; %> <% for (let order of orders){%> <%
      if(order.complete === false && order.cancelled === false){%><%
      numOfNewOrders++; }}%>

      <a class="notification">
        <%if(numOfNewOrders > 0) { %>
        <span class="badge"><%=numOfNewOrders%></span>
        <%}%>
        <select class="dropdown" id="orders">
          <%if(numOfNewOrders > 0) { %>
          <option id="notificationDropdownLabel">New Orders</option>
          <%} else { %>
          <option id="notificationDropdownLabel">No New Orders</option>
          <%}%> <% for (let order of orders){%> <%if(order.complete === false &&
          order.cancelled === false){%>
          <option disabled>order from room <%=order.room%></option>
          <%}}%>
        </select>
      </a>

      <a>
        <label class="on-off">
          <% if(headerData.enabled === false) { %>
          <input class="toggle" type="checkbox" id="myCheckbox" />
          <span class="dis-en"></span>
          <% if(headerData.reason) { %>
          <h4 style="padding-top: 10px; font-size: 0.75rem">
            Orders Disabled (<%=headerData.reason%>)
          </h4>
          <%} else { %>
          <h4 style="padding-top: 10px">Orders Disabled</h4>
          <% } %> <% } else { %>
          <input
            class="toggle"
            type="checkbox"
            id="myCheckbox"
            checked="checked"
          />
          <span class="dis-en"></span>
          <h4 style="padding-top: 10px">Orders Enabled</h4>
          <% } %>
        </label>
      </a>
    </div>
    <div id="leftTrigger"><span>&rarr;</span></div>
    <script>
      // Make arrow trigger open sidebar on hover (desktop only)
      if (window.innerWidth > 768) {
        const leftTrigger = document.getElementById('leftTrigger');
        const sidebar = document.getElementById('sidebar');
        let autoCloseTimer;
        if (leftTrigger && sidebar) {
          const collapsedLeft = '20px';
          const expandedLeft = '200px';
          const setTriggerCollapsed = function() {
            leftTrigger.style.left = collapsedLeft;
          };
          const setTriggerExpanded = function() {
            leftTrigger.style.left = expandedLeft;
          };
          const openSidebar = function() {
            sidebar.style.setProperty('transform', 'translateX(0)', 'important');
            setTriggerExpanded();
          };
          const scheduleClose = function() {
            clearTimeout(autoCloseTimer);
            autoCloseTimer = setTimeout(function() {
              if (!sidebar.matches(':hover') && !leftTrigger.matches(':hover')) {
                sidebar.style.removeProperty('transform');
                setTriggerCollapsed();
              }
            }, 700);
          };
          leftTrigger.addEventListener('mouseenter', function() {
            clearTimeout(autoCloseTimer);
            openSidebar();
          });
          leftTrigger.addEventListener('mouseleave', function() {
            scheduleClose();
          });
          sidebar.addEventListener('mouseenter', function() {
            clearTimeout(autoCloseTimer);
            setTriggerExpanded();
          });
          sidebar.addEventListener('mouseleave', function() {
            scheduleClose();
          });
          leftTrigger.addEventListener('click', function() {
            openSidebar();
            scheduleClose();
          });
          setTriggerCollapsed();
        }
      }
    </script>
    <style>
      .notification {
        position: relative;
      }

      .badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: red;
        color: white;
        padding: 5px 8px;
        border-radius: 50%;
        font-size: 12px;
        display: flex;
        height: 25px;
        min-width: 25px;
        align-items: center;
      }
    </style>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/notifications.js"></script>
    <script src="/js/refreshOrderingToggle.js"></script>
    <script src="/js/toggleEnabled.js"></script>
    <!-- Add sw-update to listen for updates -->
    <script src="/js/sw-update.js"></script>
  </body>
</html>
