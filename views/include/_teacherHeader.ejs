<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Half Caf</title>
    <link rel="stylesheet" href="/css/pico.min.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="shortcut icon" type="image/png" href="/img/logo.png" />
    <style>
      @media screen and (max-width: 768px) {
        .full-title {
          display: none;
        }
        #leftTrigger {
          display: none;
        }
      }
      @media screen and (min-width: 769px) {
        .mobile-title {
          display: none;
        }
        /* Updated arrow trigger styling */
        #leftTrigger {
          position: fixed;
          top: 50%;
          left: 20px; /* attached to collapsed sidebar edge */
          transform: translateY(-50%);
          width: 24px;
          height: 24px;
          background: var(--coffee-medium);
          cursor: pointer;
          z-index: 1003; /* Higher than sidebar so it's clickable */
          transition: left 0.3s ease;
          opacity: 0.9;
          border-radius: 4px;
          display: flex;
          align-items: center;
          justify-content: center;
        }
        #leftTrigger span {
          display: block;
          text-align: center;
          color: white;
          line-height: 24px;
          font-size: 14px;
        }
        /* Arrow position is controlled by JS to avoid stale position */
      }
    </style>
  </head>
  <body>
    <div class="indexTopBar">
      <div class="container" id="logo">
        <%- include('_header') %>
        <h1 id="title" class="indexTopBar">
          <% if (headerData.enabled === false){ %>
          <div id="disabledBanner" style="color: #f5ae43">
            <span class="full-title">ORDERING DISABLED</span>
            <span class="mobile-title">DISABLED</span>
          </div>
          <% } else { %>
          <span class="full-title">NNHS Half Caf</span>
          <span class="mobile-title">Half Caf</span>
          <% } %>
        </h1>
      </div>
    </div>

    <!-- Reorder: sidebar appears first, arrow trigger immediately after -->
    <div id="sidebar">
      <a href="/teacher/popularDrinks">Popular Drinks</a>
      <a href="/teacher/menu">Menu</a>
      <a href="/teacher/myFavorites">My Favorites</a>
      <a href="/teacher/myCart">My Cart</a>
      <a href="/teacher/outgoingOrders">Outgoing Orders</a>
      <a href="/teacher/orderHistory">Order History</a>

      <a href="https://forms.gle/uqQ8SiAY4BUPCTJp8" target="_blank">Feedback</a>
      <a href="https://forms.gle/MuZF7T39r9adDQRT8" target="_blank"
        >Report a bug</a
      >
      <% if (role === "admin") { %>
      <a href="/admin/users">Admin</a>
      <% } %>
      <a href="/auth/logout">Logout</a>
    </div>
    <div id="leftTrigger"><span>&rarr;</span></div>

    <style>
      #noOrder {
        margin-top: 3%;
        margin-right: 5%;
        margin-left: 3%;
        max-width: 40%;
      }
      #logout {
        float: left;
        color: #f2f2f2;
        text-align: center;
        padding: 14px 16px;
        text-decoration: none;
        font-size: 17px;
        background-color: #3f93d8;
        margin-right: 5%;
        border-radius: 5px;
      }
      #logout:hover {
        background-color: #f5ae43;
      }
    </style>

    <input class="emailInput" type="hidden" value="<%=email%>" />
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/notifications.js"></script>
    <script src="/js/refreshOrderingToggle.js"></script>
    <!-- Add sw-update to listen for updates -->
    <script src="/js/sw-update.js"></script>
    <script>
      // Make arrow trigger open sidebar on hover (desktop only)
      if (window.innerWidth > 768) {
        const leftTrigger = document.getElementById('leftTrigger');
        const sidebar = document.getElementById('sidebar');
        let autoCloseTimer;
        if (leftTrigger && sidebar) {
          const collapsedLeft = '20px';
          const expandedLeft = '200px';
          const setTriggerCollapsed = function() {
            leftTrigger.style.left = collapsedLeft;
          };
          const setTriggerExpanded = function() {
            leftTrigger.style.left = expandedLeft;
          };
          const openSidebar = function() {
            sidebar.style.setProperty('transform', 'translateX(0)', 'important');
            setTriggerExpanded();
          };
          const scheduleClose = function() {
            clearTimeout(autoCloseTimer);
            autoCloseTimer = setTimeout(function() {
              if (!sidebar.matches(':hover') && !leftTrigger.matches(':hover')) {
                sidebar.style.removeProperty('transform');
                setTriggerCollapsed();
              }
            }, 5);
          };
          leftTrigger.addEventListener('mouseenter', function() {
            clearTimeout(autoCloseTimer);
            openSidebar();
          });
          leftTrigger.addEventListener('mouseleave', function() {
            scheduleClose();
          });
          sidebar.addEventListener('mouseenter', function() {
            clearTimeout(autoCloseTimer);
            setTriggerExpanded();
          });
          sidebar.addEventListener('mouseleave', function() {
            scheduleClose();
          });
          leftTrigger.addEventListener('click', function() {
            openSidebar();
            scheduleClose();
          });
          setTriggerCollapsed();
        }
      }
    </script>
  </body>
</html>
