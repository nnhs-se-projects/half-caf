<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>My Outgoing Orders</title>
  </head>
  <body>
    <%- include('include/_teacherHeader') %>

    <div id="mainContent">
      <div class="header-section">
        <h2>My Outgoing Orders</h2>
        <div class="coffee-decoration">☕</div>
      </div>

      <div class="orders-container">
        <% if (orders.length === 0) { %>
        <div class="empty-orders">
          <div class="coffee-icon">☕</div>
          <p>No outgoing orders found. Ready to place one?</p>
          <a href="/teacher/menu" class="browse-menu-btn">Browse Menu</a>
        </div>
        <% } else { %>
        <div class="order-list">
          <% let i = 0; %> <% orders.forEach(order => { %>
          <div class="order-card">
            <div class="room-badge">
              Room
              <span class="room-display" data-order-id="<%= order._id %>"
                ><%= order.room %></span
              >
              <button
                class="edit-room"
                data-order-id="<%= order._id %>"
                title="Click to edit room number"
              >
                <svg
                  class="edit-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  xmlns="http://www.w3.org/2000/svg"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M15.5 5.5L18.5 8.5M12 19H19M5 15.5L15.5 5.5L18.5 8.5L8 19H5V15.5Z"
                  />
                </svg>
              </button>
              <div class="edit-controls" style="display: none">
                <input
                  type="text"
                  class="room-input"
                  data-order-id="<%= order._id %>"
                  value="<%= order.room %>"
                  maxlength="10"
                />
                <button class="save-room" data-order-id="<%= order._id %>">
                  Save
                </button>
              </div>
            </div>
            <div class="order-status">
              <span class="status-badge">In Progress</span>
            </div>
            <div class="order-header">
              <h3>Order Details</h3>
              <div class="order-time"><%= order.timestamp.split('/')[0] %></div>
            </div>
            <div class="order-price">
              <span class="price-label">Total:</span>
              <span class="price-value"
                >$<%= order.totalPrice.toFixed(2) %></span
              >
            </div>
            <div class="drinks-container">
              <h4>Drinks</h4>
              <ul class="drinks-list">
                <% orderObjectArray[i].drinks.forEach(drink => { %>
                <li class="drink-item">
                  <div class="drink-name"><%= drink.name %></div>
                  <div class="drink-details">
                    <span class="temp-badge <%= drink.temps %>">
                      <%= drink.temps %>
                    </span>
                    <span class="caffeination-badge <%= drink.caffeinated ? 'caffeinated' : 'decaf' %>">
                      <%= drink.caffeinated ? "☕ Caffeinated" : "😌 Decaf" %>
                    </span>

                    <% if (drink.ingredients && drink.ingredients.length) { %>
                    <% let allIngredients = ""; %> <% for(let i = 0; i <
                    drink.ingredients.length; i++) {
                    if(drink.ingredients[i].type == "customizable") {
                    allIngredients += (drink.ingredientCounts[i] == 0 ? "No " :
                    drink.ingredientCounts[i] + " ") + drink.ingredients[i].name
                    + ", "; } } %>
                    <div class="drink-ingredients">
                      <%= allIngredients.substring(0, allIngredients.length-2)
                      %>
                    </div>
                    <% } %> %> <% if (drink.instructions) { %>
                    <div class="drink-instructions">
                      "<%= drink.instructions %>"
                    </div>
                    <% } %>
                  </div>
                </li>
                <% }) %>
              </ul>
            </div>
            <% if (order.confirmedAt) { %>
            <div class="order-actions">
              <button class="cancel-order-btn" data-order-id="<%= order._id %>" title="Cancel order (available for 30 seconds after confirmation)">
                <span class="cancel-text">Cancel Order</span>
                <span class="cancel-timer" data-order-id="<%= order._id %>" data-confirmed-at="<%= order.confirmedAt.toISOString() %>"></span>
              </button>
            </div>
            <% } %>
          </div>
          <% i++; %> <% }) %>
        </div>
        <% } %>
      </div>
    </div>

    <script src="/js/outgoingOrders.js"></script>

    <%- include('include/_footer') %>
  </body>
  <style>
    /* Coffee-themed color variables */
    :root {
      --coffee-dark: #3c2a21;
      --coffee-medium: #967259;
      --coffee-light: #d8b6a4;
      --cream: #f8f1e9;
      --accent: #f5ae43;
    }

    body {
      background: var(--cream);
      font-family: sans-serif;
      margin: 0;
      /* Remove the body padding that's causing the sidebar issue */
      /* padding: 2rem; */
    }

    #mainContent {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem;
    }

    .header-section {
      display: flex;
      align-items: center;
      margin-bottom: 2rem;
    }

    .header-section h2 {
      color: var(--coffee-dark);
      font-size: 2rem;
      margin: 0;
      margin-right: 1rem;
    }

    .coffee-decoration {
      font-size: 2rem;
      animation: steam 2s ease-in-out infinite;
    }

    @keyframes steam {
      0%,
      100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    .empty-orders {
      text-align: center;
      padding: 3rem 1rem;
    }

    .coffee-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }

    .empty-orders p {
      color: var(--coffee-medium);
      font-size: 1.1rem;
      margin-bottom: 2rem;
    }

    .browse-menu-btn {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: var(--accent);
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      transition: all 0.2s ease;
    }

    .browse-menu-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(245, 174, 67, 0.3);
    }

    .orders-container {
      background: white;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 2px 12px rgba(60, 42, 33, 0.1);
    }

    .order-list {
      display: grid;
      gap: 1.5rem;
    }

    .order-card {
      border: 2px solid #e0e0e0;
      border-radius: 12px;
      padding: 1.5rem;
      background: white;
      transition: all 0.2s ease;
    }

    .order-card:hover {
      border-color: var(--accent);
      box-shadow: 0 4px 12px rgba(245, 174, 67, 0.15);
    }

    .room-badge {
      display: inline-block;
      background: var(--coffee-light);
      color: var(--coffee-dark);
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-weight: 600;
      margin-bottom: 1rem;
      position: relative;
    }

    .room-display {
      font-weight: bold;
      margin: 0 0.25rem;
    }

    .edit-room {
      background: none;
      border: none;
      cursor: pointer;
      margin-left: 0.5rem;
      color: var(--coffee-dark);
      width: 20px;
      height: 20px;
      padding: 0;
      display: inline-flex;
      align-items: center;
    }

    .edit-icon {
      width: 100%;
      height: 100%;
      stroke-width: 2;
    }

    .edit-controls {
      display: flex;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }

    .room-input {
      padding: 0.5rem;
      border: 1px solid var(--coffee-medium);
      border-radius: 4px;
      font-size: 1rem;
    }

    .save-room {
      padding: 0.5rem 1rem;
      background: var(--accent);
      color: white;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: 600;
    }

    .order-status {
      margin-bottom: 1rem;
    }

    .status-badge {
      display: inline-block;
      background: #e8f5e9;
      color: #2e7d32;
      padding: 0.5rem 1rem;
      border-radius: 20px;
      font-size: 0.9rem;
      font-weight: 600;
    }

    .order-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      border-bottom: 1px solid #f0f0f0;
      padding-bottom: 1rem;
    }

    .order-header h3 {
      margin: 0;
      color: var(--coffee-dark);
      font-size: 1.2rem;
    }

    .order-time {
      color: var(--coffee-medium);
      font-size: 0.9rem;
    }

    .order-price {
      background: var(--cream);
      padding: 1rem;
      border-radius: 8px;
      margin-bottom: 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .price-label {
      color: var(--coffee-dark);
      font-weight: 600;
    }

    .price-value {
      font-size: 1.5rem;
      color: var(--accent);
      font-weight: bold;
    }

    .drinks-container h4 {
      color: var(--coffee-dark);
      margin-bottom: 1rem;
      margin-top: 1.5rem;
      font-size: 1.1rem;
    }

    .drinks-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }

    .drink-item {
      border: 1px solid #f0f0f0;
      border-radius: 8px;
      padding: 1rem;
      background: #fafafa;
    }

    .drink-name {
      font-weight: 600;
      color: var(--coffee-dark);
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
    }

    .drink-details {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      align-items: center;
    }

    .temp-badge,
    .caffeination-badge {
      display: inline-block;
      padding: 0.4rem 0.8rem;
      border-radius: 12px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .temp-badge {
      background: #e3f2fd;
      color: #1565c0;
    }

    .temp-badge.hot {
      background: #ffebee;
      color: #c62828;
    }

    .temp-badge.iced {
      background: #f3e5f5;
      color: #6a1b9a;
    }

    .temp-badge.blended {
      background: #e0f2f1;
      color: #00695c;
    }

    .caffeination-badge {
      background: #fff3e0;
      color: #e65100;
    }

    .caffeination-badge.decaf {
      background: #f3e5f5;
      color: #6a1b9a;
    }

    .drink-ingredients {
      font-size: 0.9rem;
      color: var(--coffee-medium);
      flex: 1;
    }

    .drink-instructions {
      font-size: 0.9rem;
      font-style: italic;
      color: #666;
      width: 100%;
      padding-top: 0.5rem;
      border-top: 1px solid #eee;
    }

    .order-actions {
      display: flex;
      gap: 1rem;
      margin-top: 1.5rem;
      padding-top: 1rem;
      border-top: 1px solid #f0f0f0;
    }

    .cancel-order-btn {
      background: #ff6b6b;
      color: white;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.2s ease;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .cancel-order-btn:hover {
      background: #ff5252;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(255, 107, 107, 0.3);
    }

    .cancel-text {
      flex: 1;
    }

    .cancel-timer {
      font-size: 0.8rem;
      opacity: 0.9;
    }

    @media screen and (max-width: 768px) {
      #mainContent {
        padding: 0.5rem;
      }

      .header-section {
        flex-direction: column;
        align-items: flex-start;
        margin-bottom: 1rem;
      }

      .header-section h2 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
      }

      .orders-container {
        padding: 1rem;
      }

      .order-card {
        padding: 1rem;
      }

      .drink-details {
        flex-direction: column;
        align-items: flex-start;
      }

      .order-header {
        flex-direction: column;
        align-items: flex-start;
      }

      .order-time {
        margin-top: 0.5rem;
      }

      .cancel-order-btn {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

    <script src="/js/outgoingOrders.js"></script>
</html>
